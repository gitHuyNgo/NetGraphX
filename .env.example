NETBOX_URL=http://localhost:8000
NETBOX_API_TOKEN=your_token_here
DEBUG=true

NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# RAG Pipeline — LLM configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Webhook receiver — debounced NetBox change integration
WEBHOOK_SECRET=your_webhook_secret_here
WEBHOOK_PORT=5001
# Minutes of silence after last NetBox change before auto-sync triggers
WEBHOOK_DEBOUNCE_MINUTES=10
WEBHOOK_STATE_FILE=data/storage/webhook_state.json

# RBAC
USERS_FILE=config/users.yaml
SESSION_SECRET=change-this-to-a-long-random-secret